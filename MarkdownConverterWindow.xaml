<Window x:Class="COMIGHT.MarkdownConverterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Markdown Converter" Style="{StaticResource BaseWindowStyle}" Width="600" Height="480" WindowStartupLocation="CenterScreen" >

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBox x:Name="txtbxHint" Grid.Row="0" Margin="5" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" IsReadOnly="True" BorderBrush="Transparent" BorderThickness="0" Background="Transparent" Text="Input text below:"/>

        <TextBox x:Name="txtbxMarkdown" Grid.Row ="1" Margin="5" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" IsReadOnly="False" AcceptsReturn="True"/>

        <StackPanel Grid.Row="2" Margin="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button IsDefault="True" Content="Convert" Click="btnConvert_Click" />
            <Button IsCancel="True" Content="Exit" Click="btnExit_Click" />
        </StackPanel>

    </Grid>
</Window>
